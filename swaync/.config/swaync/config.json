{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "positionX": "right",
  "positionY": "top",
	"cssPriority": "user",

  "control-center-width": 380,
  "control-center-height": 1040, 
  "control-center-margin-top": 2,
  "control-center-margin-bottom": 2,
  "control-center-margin-right": 1,
  "control-center-margin-left": 0,

  "notification-window-width": 400,
  "notification-body-image-height": 160,
  "notification-body-image-width": 200,

  "timeout": 10,
  "timeout-low": 8,
  "timeout-critical": 15,
  
  "fit-to-screen": false,
  "keyboard-shortcuts": true,
  "image-visibility": "when-available",
  "transition-time": 200,
  "hide-on-clear": false,
  "hide-on-action": false,
  "script-fail-notify": true,
  "scripts": {
    "example-script": {
      "exec": "echo 'Do something...'",
      "urgency": "Normal"
    }
  },
  "notification-visibility": {
    "example-name": {
      "state": "muted",
      "urgency": "Low",
      "app-name": "Spotify"
    }
  },
  "widgets": [
    "label",
    "buttons-grid",
    "mpris",
    "title",
    "dnd",
    "notifications"
  ],
  "widget-config": {
    "title": {
      "text": "Notifications",
      "clear-all-button": true,
      "button-text": " 󰎟 "
    },
    "dnd": {
      "text": "Do not disturb"
    },
    "label": {
      "max-lines": 1,
      "text": "Flight Controls"
    },
    "mpris": {
      "image-size": 96,
      "autohide": true,
      "show-album-art": "when-available"
    },
    "volume": {
      "label": "󰕾",
        "show-per-app": true
    },
    "buttons-grid": {
      "actions": [
        {
          "label": "󰛨",
          "command": "toggle_nightmode"
        },
        {
          "label": "󰀝",
          "command": "nmcli radio wifi off && notify-send 'Airplane Mode' 'Enabled' || nmcli radio wifi on && notify-send 'Airplane Mode' 'Disabled'"
        },
        {
          "label": "󰂯",
          "command": "blueman-manager"
        },
        {
          "label": "󰖁",
          "command": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"
        },
        {
          "label": "󰏘",
          "command": "nwg-look"
        }
        
      ]
    }
  }
}
